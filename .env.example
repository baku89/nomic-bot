# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# LLM provider: gemini | claude | openai
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# Provide the key matching LLM_PROVIDER
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Where all game .md files live (separate git repo)
GAMES_DIR=/var/lib/nomic-games

# Discord user IDs allowed to start new games (JSON array of strings)
ALLOWLIST_PATH=./config/allowlist.json

# How the bot identifies itself in prompts
BOT_DISPLAY_NAME=Nomic
